@model Musteri
@{
    ViewData["Title"] = "Müşteri sil";
}

<h1>@ViewData["Title"]</h1>
<h3 class="text-danger">Bu kaydı silmek istediğinize emin misiniz?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.AdSoyad)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(m => m.AdSoyad)</dd>
    <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Telefon)</dt>
    <dd class="col-sm-10">@Html.DisplayFor(m => m.Telefon)</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a class="btn btn-outline-secondary" asp-action="Index">İptal</a>
</form>
