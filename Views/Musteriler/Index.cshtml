@model IEnumerable<Musteri>
@{
    ViewData["Title"] = "Müşteriler";
}

<h1>@ViewData["Title"]</h1>
@if (TempData["Hata"] is string h && !string.IsNullOrEmpty(h))
{
    <div class="alert alert-warning">@h</div>
}
<p>
    <a class="btn btn-primary" asp-action="Create">Yeni müşteri</a>
</p>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.AdSoyad)</th>
            <th>@Html.DisplayNameFor(m => m.Telefon)</th>
            <th>@Html.DisplayNameFor(m => m.Email)</th>
            <th>@Html.DisplayNameFor(m => m.TcKimlikNo)</th>
            <th style="width:220px">İşlemler</th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@Html.DisplayFor(m => item.AdSoyad)</td>
            <td>@Html.DisplayFor(m => item.Telefon)</td>
            <td>@Html.DisplayFor(m => item.Email)</td>
            <td>@Html.DisplayFor(m => item.TcKimlikNo)</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detay</a>
                <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Sil</a>
            </td>
        </tr>
}
    </tbody>
</table>
