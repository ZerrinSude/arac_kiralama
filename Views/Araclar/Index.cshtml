@model IEnumerable<Arac>
@{
    ViewData["Title"] = User.IsInRole("Admin") ? "Araçlar" : "Müsait araçlar";
    var adminMi = User.IsInRole("Admin");
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Basari"] is string basari)
{
    <div class="alert alert-success">@basari</div>
}
@if (TempData["Hata"] is string h && !string.IsNullOrEmpty(h))
{
    <div class="alert alert-warning">@h</div>
}

@if (adminMi)
{
    <p class="mb-3">
        <a class="btn btn-primary" asp-controller="Araçlar" asp-action="Create">Yeni araç</a>
    </p>
}

<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(m => m.Marka)</th>
            <th>@Html.DisplayNameFor(m => m.Model)</th>
            <th>@Html.DisplayNameFor(m => m.Plaka)</th>
            <th>@Html.DisplayNameFor(m => m.GunlukUcret)</th>
            @if (adminMi)
            {
                <th>@Html.DisplayNameFor(m => m.Musait)</th>
                <th style="width:220px">İşlemler</th>
            }
            else
            {
                <th style="width:120px"></th>
            }
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Marka</td>
            <td>@item.Model</td>
            <td>@item.Plaka</td>
            <td>@item.GunlukUcret.ToString("N2") ₺</td>
            @if (adminMi)
            {
                <td>@(item.Musait ? "Evet" : "Hayır")</td>
                <td>
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detay</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Sil</a>
                </td>
            }
            else
            {
                <td>
                    <a class="btn btn-sm btn-success" asp-controller="Kiralamalar" asp-action="Create">Kirala</a>
                </td>
            }
        </tr>
}
    </tbody>
</table>
