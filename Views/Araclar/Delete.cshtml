@model Arac
@{
    ViewData["Title"] = "Araç sil";
}

<h1>@ViewData["Title"]</h1>
<h3 class="text-danger">Bu kaydı silmek istediğinize emin misiniz?</h3>
<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Marka)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Marka)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Model)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Model)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(m => m.Plaka)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(m => m.Plaka)</dd>
    </dl>
    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Sil</button>
        <a class="btn btn-outline-secondary" asp-action="Index">İptal</a>
    </form>
</div>
