@model LoginViewModel
@{
    ViewData["Title"] = "Admin girişi";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-3">Admin girişi</h1>
        <p class="text-muted">Yönetim paneli: araç, müşteri ve tüm kiralamalar.</p>
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="LoginAdmin" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="KullaniciAdi" class="form-label"></label>
                        <input asp-for="KullaniciAdi" class="form-control" autocomplete="username" />
                        <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Sifre" class="form-label"></label>
                        <input asp-for="Sifre" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Sifre" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Giriş yap</button>
                </form>
                <p class="small text-muted mt-3 mb-0">Demo: kullanıcı <strong>admin</strong> / şifre <strong>admin123</strong></p>
            </div>
        </div>
        <p class="mt-3">
            <a asp-action="LoginMusteri">Müşteri girişi</a> ·
            <a asp-controller="Home" asp-action="Index">Ana sayfa</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
