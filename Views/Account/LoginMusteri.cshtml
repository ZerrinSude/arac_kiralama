@model LoginViewModel
@{
    ViewData["Title"] = "Müşteri girişi";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <h1 class="h3 mb-3">Müşteri girişi</h1>
        <p class="text-muted">Müsait araçları görüntüleyin ve kiralama talebi oluşturun.</p>
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="LoginMusteri" method="post">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label asp-for="KullaniciAdi" class="form-label"></label>
                        <input asp-for="KullaniciAdi" class="form-control" autocomplete="username" />
                        <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Sifre" class="form-label"></label>
                        <input asp-for="Sifre" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="Sifre" class="text-danger"></span>
                    </div>
                    <button type="submit" class="btn btn-primary w-100">Giriş yap</button>
                </form>
                <p class="small text-muted mt-3 mb-0">Demo: kullanıcı <strong>musteri</strong> / şifre <strong>musteri123</strong></p>
            </div>
        </div>
        <p class="mt-3">
            Hesabınız yok mu? <a asp-action="Register"><strong>Kayıt ol</strong></a><br />
            <a asp-action="LoginAdmin">Admin girişi</a> ·
            <a asp-controller="Home" asp-action="Index">Ana sayfa</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
