@model MusteriKayitViewModel
@{
    ViewData["Title"] = "Müşteri kayıt";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <h1 class="h3 mb-3">Müşteri kayıt</h1>
        <p class="text-muted">Hesap oluşturarak müsait araçları görüntüleyebilir ve kiralama talebi verebilirsiniz.</p>
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <h5 class="mb-3">Giriş bilgileri</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="KullaniciAdi" class="form-label"></label>
                            <input asp-for="KullaniciAdi" class="form-control" autocomplete="username" />
                            <span asp-validation-for="KullaniciAdi" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="AdSoyad" class="form-label"></label>
                            <input asp-for="AdSoyad" class="form-control" />
                            <span asp-validation-for="AdSoyad" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Sifre" class="form-label"></label>
                            <input asp-for="Sifre" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="Sifre" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="SifreTekrar" class="form-label"></label>
                            <input asp-for="SifreTekrar" class="form-control" autocomplete="new-password" />
                            <span asp-validation-for="SifreTekrar" class="text-danger"></span>
                        </div>
                    </div>

                    <h5 class="mb-3 mt-2">İletişim bilgileri</h5>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="Telefon" class="form-label"></label>
                            <input asp-for="Telefon" class="form-control" placeholder="0555 555 55 55" />
                            <span asp-validation-for="Telefon" class="text-danger"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="Email" class="form-label"></label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label asp-for="TcKimlikNo" class="form-label"></label>
                        <input asp-for="TcKimlikNo" class="form-control" maxlength="11" />
                        <span asp-validation-for="TcKimlikNo" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-success w-100">Kayıt ol</button>
                </form>
            </div>
        </div>
        <p class="mt-3 mb-0">
            Zaten hesabınız var mı? <a asp-action="LoginMusteri">Müşteri girişi</a>
        </p>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
