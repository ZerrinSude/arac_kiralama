@model Kiralama
@{
    ViewData["Title"] = "Kiralama sil";
}

<h1>@ViewData["Title"]</h1>
<h3 class="text-danger">Bu kaydı silmek istediğinize emin misiniz?</h3>
<hr />
<dl class="row">
    <dt class="col-sm-2">Araç</dt>
    <dd class="col-sm-10">@(Model.Arac?.ListeEtiketi ?? "-")</dd>
    <dt class="col-sm-2">Müşteri</dt>
    <dd class="col-sm-10">@(Model.Musteri?.AdSoyad ?? "-")</dd>
    <dt class="col-sm-2">Başlangıç</dt>
    <dd class="col-sm-10">@Model.BaslangicTarihi.ToString("d")</dd>
    <dt class="col-sm-2">Bitiş</dt>
    <dd class="col-sm-10">@Model.BitisTarihi.ToString("d")</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Sil</button>
    <a class="btn btn-outline-secondary" asp-action="Index">İptal</a>
</form>
