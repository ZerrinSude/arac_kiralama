@model IEnumerable<Kiralama>
@{
    var adminMi = User.IsInRole("Admin");
    ViewData["Title"] = adminMi ? "Kiralamalar" : "Kiralamalarım";
}

<h1>@ViewData["Title"]</h1>
@if (TempData["Basari"] is string basari)
{
    <div class="alert alert-success">@basari</div>
}
@if (TempData["Hata"] is string hata)
{
    <div class="alert alert-warning">@hata</div>
}
<p>
    <a class="btn btn-primary" asp-action="Create">@(adminMi ? "Yeni kiralama" : "Yeni kiralama talebi")</a>
</p>
<table class="table table-striped table-bordered">
    <thead>
        <tr>
            <th>Araç</th>
            @if (adminMi) { <th>Müşteri</th> }
            <th>Başlangıç</th>
            <th>Bitiş</th>
            <th>Toplam tutar</th>
            @if (adminMi) { <th style="width:220px">İşlemler</th> }
            else { <th style="width:100px"></th> }
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@(item.Arac?.ListeEtiketi ?? "-")</td>
            @if (adminMi) { <td>@(item.Musteri?.AdSoyad ?? "-")</td> }
            <td>@item.BaslangicTarihi.ToString("d")</td>
            <td>@item.BitisTarihi.ToString("d")</td>
            <td>@item.ToplamTutar.ToString("N2") ₺</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Details" asp-route-id="@item.Id">Detay</a>
                @if (adminMi)
                {
                    <a class="btn btn-sm btn-outline-primary" asp-action="Edit" asp-route-id="@item.Id">Düzenle</a>
                    <a class="btn btn-sm btn-outline-danger" asp-action="Delete" asp-route-id="@item.Id">Sil</a>
                }
            </td>
        </tr>
}
    </tbody>
</table>
