@model Kiralama
@{
    ViewData["Title"] = "Kiralama düzenle";
}

<h1>@ViewData["Title"]</h1>

<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="mb-3">
                <label asp-for="AracId" class="form-label"></label>
                <select asp-for="AracId" class="form-select" asp-items="ViewBag.AracId"></select>
                <span asp-validation-for="AracId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="MusteriId" class="form-label"></label>
                <select asp-for="MusteriId" class="form-select" asp-items="ViewBag.MusteriId"></select>
                <span asp-validation-for="MusteriId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BaslangicTarihi" class="form-label"></label>
                <input asp-for="BaslangicTarihi" class="form-control" type="date" />
                <span asp-validation-for="BaslangicTarihi" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="BitisTarihi" class="form-label"></label>
                <input asp-for="BitisTarihi" class="form-control" type="date" />
                <span asp-validation-for="BitisTarihi" class="text-danger"></span>
            </div>
            <p class="small text-muted">Mevcut toplam: <strong>@Model.ToplamTutar.ToString("N2") ₺</strong> (kaydedince güncellenir)</p>
            <button type="submit" class="btn btn-primary">Kaydet</button>
            <a class="btn btn-outline-secondary" asp-action="Index">İptal</a>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
